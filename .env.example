# ============================================================
# Strategic Radar — 环境变量样板 (.env.example)
# 使用方式:
#   cp .env.example .env
#   并按实际填入真实凭证 (绝对不要把 .env 提交到 git)
# ============================================================

# ---------- Django ----------
# 生产: 0；开发: 1
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=please-change-me-in-production
# 生产建议显式列出域名: example.com,api.example.com,127.0.0.1
DJANGO_ALLOWED_HOSTS=*
# CORS 白名单 (逗号分隔)；空字符串 + DEBUG=0 表示完全禁用跨域
DJANGO_CORS_ORIGINS=
# ---------- 生产安全头 (DEBUG=0 时生效) ----------
# HSTS 有效期 (默认 1 年); 首次上线可设为 60 调试
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_HSTS_PRELOAD=1
# 反向代理已终结 SSL 时可设 DJANGO_SSL_REDIRECT=0
DJANGO_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1

# ---------- 数据库 / 缓存 ----------
PG_DB=strategic_radar
PG_USER=postgres
PG_PASSWORD=please-change-me
PG_HOST=127.0.0.1
PG_PORT=5432
REDIS_URL=redis://127.0.0.1:6379

# ---------- LLM (DeepSeek / OpenAI 兼容) ----------
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-replace-with-your-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ---------- 邮件 ----------
# 真发: django.core.mail.backends.smtp.EmailBackend
# 演示: django.core.mail.backends.filebased.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USE_TLS=0
EMAIL_HOST_USER=your-mailbox@qq.com
EMAIL_HOST_PASSWORD=your-smtp-auth-code
DEFAULT_FROM_EMAIL=your-mailbox@qq.com

# ---------- 飞书机器人 ----------
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
FEISHU_WEBHOOK_SECRET=

# ---------- 数据源采集模式 ----------
# auto: 真采失败超阈值后自动降级仿真; simulated: 强制仿真; real: 仅真采
DATA_SOURCE_MODE=auto
CRAWLER_FAILURE_THRESHOLD=3
FALLBACK_ON_FAILURE=1
MIN_SIMULATED_ITEMS=1

# ---------- 阿里云短信 (备用) ----------
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ---------- 默认收件方 ----------
DEFAULT_RECIPIENT_EMAIL=demo@example.com
DEFAULT_RECIPIENT_NAME=战略情报负责人

# ---------- 真实爬虫 API Key (可选) ----------
FRED_API_KEY=
